{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/OpenCoven/coven-runtimes/schema/adapter-manifest.schema.json",
  "title": "Coven Runtime Adapter Manifest",
  "description": "A manifest declaring one or more runtime adapters for the Coven. Backward-compatible superset of coven's ExternalHarnessAdapterSpec.",
  "type": "object",
  "required": ["adapters"],
  "additionalProperties": false,
  "properties": {
    "adapters": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/adapter" }
    }
  },
  "definitions": {
    "adapter": {
      "type": "object",
      "required": ["id", "label", "executable", "install_hint"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9._-]+$",
          "description": "Canonical id: lowercase letters, digits, '.', '_', '-'. Must not collide with built-ins (codex, claude)."
        },
        "label": { "type": "string", "minLength": 1 },
        "executable": {
          "type": "string",
          "pattern": "^[^/\\\\\\s]+$",
          "description": "Bare command name — no path separators or whitespace."
        },
        "interactive_prompt_prefix_args": {
          "type": "array", "items": { "type": "string" }
        },
        "interactivePromptPrefixArgs": {
          "type": "array", "items": { "type": "string" }
        },
        "non_interactive_prompt_prefix_args": {
          "type": "array", "items": { "type": "string" }
        },
        "nonInteractivePromptPrefixArgs": {
          "type": "array", "items": { "type": "string" }
        },
        "install_hint": { "type": "string", "minLength": 1 },
        "system_prompt_flag": { "type": ["string", "null"] },
        "systemPromptFlag": { "type": ["string", "null"] },
        "model_flag": { "type": ["string", "null"] },
        "modelFlag": { "type": ["string", "null"] },
        "model_arg_template": {
          "type": ["string", "null"],
          "description": "argv template with a {model} placeholder."
        },
        "modelArgTemplate": { "type": ["string", "null"] },
        "capabilities": { "$ref": "#/definitions/capabilities" },
        "sandbox": { "$ref": "#/definitions/sandbox" },
        "stream_args": { "$ref": "#/definitions/streamArgs" },
        "streamArgs": { "$ref": "#/definitions/streamArgs" },
        "version": { "type": "string" },
        "homepage": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "description": "Behavioral opt-ins. All default to false (baseline one-shot CLI).",
      "properties": {
        "stream": { "type": "boolean", "description": "Long-lived stream-json mode. Requires stream_args." },
        "preassigned_session_id": { "type": "boolean" },
        "preassignedSessionId": { "type": "boolean" },
        "think": { "type": "boolean" },
        "speed": { "type": "boolean" }
      }
    },
    "sandbox": {
      "description": "Maps a permission policy to the runtime's native sandbox args. Two forms: a single `--flag value` pair per policy (Codex, Claude), or a whole argv list per policy for runtimes with boolean/repeatable permission flags (GitHub Copilot CLI).",
      "oneOf": [
        {
          "type": "object",
          "required": ["flag", "full"],
          "additionalProperties": false,
          "description": "Flag form: one flag, one value per policy.",
          "properties": {
            "flag": { "type": "string", "minLength": 1 },
            "full": { "type": "string", "minLength": 1 },
            "read_only": { "type": "string", "minLength": 1 },
            "readOnly": { "type": "string", "minLength": 1 }
          }
        },
        {
          "type": "object",
          "required": [],
          "additionalProperties": false,
          "description": "Args form: a full argv list per policy (e.g. Copilot's `--allow-all` / `--deny-tool write --deny-tool shell`).",
          "anyOf": [
            { "required": ["full_args", "read_only_args"] },
            { "required": ["fullArgs", "readOnlyArgs"] },
            { "required": ["full_args", "readOnlyArgs"] },
            { "required": ["fullArgs", "read_only_args"] }
          ],
          "properties": {
            "full_args": { "type": "array", "minItems": 1, "items": { "type": "string" } },
            "fullArgs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
            "read_only_args": { "type": "array", "minItems": 1, "items": { "type": "string" } },
            "readOnlyArgs": { "type": "array", "minItems": 1, "items": { "type": "string" } }
          }
        }
      ]
    },
    "streamArgs": {
      "type": "object",
      "required": [],
      "additionalProperties": false,
      "description": "Launch args for stream-json mode. Required when capabilities.stream is true.",
      "properties": {
        "prefix_args": { "type": "array", "items": { "type": "string" } },
        "prefixArgs": { "type": "array", "items": { "type": "string" } },
        "session_id_flag": { "type": ["string", "null"] },
        "sessionIdFlag": { "type": ["string", "null"] },
        "resume_flag": { "type": ["string", "null"] },
        "resumeFlag": { "type": ["string", "null"] }
      }
    }
  }
}
